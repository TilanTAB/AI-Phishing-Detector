# =============================================================================
# Gmail Phishing Checker - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# =============================================================================

# === AI Provider ===
# Choose: "azure_openai" or "bedrock_claude"
AI_PROVIDER=azure_openai

# === Azure OpenAI (required if AI_PROVIDER=azure_openai) ===
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# === Amazon Bedrock (required if AI_PROVIDER=bedrock_claude) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# === Gmail OAuth ===
# Path to the OAuth credentials JSON downloaded from GCP Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Path where the refresh token will be stored after first auth
GOOGLE_TOKEN_FILE=token.json

# === Google Cloud Pub/Sub ===
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC=gmail-notifications
PUBSUB_VERIFICATION_TOKEN=your-secret-token

# === Server ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# === Behavior ===
SEND_WARNING_EMAIL=true
# Score thresholds (defaults shown)
SUSPICIOUS_THRESHOLD=31
PHISHING_THRESHOLD=66

# === Logging ===
LOG_LEVEL=INFO
